#!/usr/bin/env bash
set -euo pipefail

release="${ALMALINUX_RELEASE:-9.7-20260414}"
major="${ALMALINUX_MAJOR:-9}"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
output_dir="${repo_root}/build/images/almalinux-9-arm64"
work_dir="${output_dir}/work"
image_name="AlmaLinux-${major}-GenericCloud-ext4-${release}.aarch64.qcow2"
base_url="https://repo.almalinux.org/almalinux/${major}/cloud/aarch64/images"

if ! command -v curl >/dev/null 2>&1; then
  echo "curl is required to download the AlmaLinux image" >&2
  exit 1
fi

if ! command -v qemu-img >/dev/null 2>&1; then
  echo "qemu-img is required to convert the AlmaLinux cloud image to raw" >&2
  exit 1
fi

if ! command -v shasum >/dev/null 2>&1; then
  echo "shasum is required to verify the AlmaLinux image" >&2
  exit 1
fi

rm -rf "${work_dir}"
mkdir -p "${work_dir}" "${output_dir}"

curl -fsSL --output "${work_dir}/${image_name}" "${base_url}/${image_name}"
curl -fsSL --output "${work_dir}/CHECKSUM" "${base_url}/CHECKSUM"
expected_checksum="$(awk -v image_name="${image_name}" '$2 == image_name { print $1; exit }' "${work_dir}/CHECKSUM")"
actual_checksum="$(shasum -a 256 "${work_dir}/${image_name}" | awk '{print $1}')"

if [[ -z "${expected_checksum}" ]]; then
  echo "failed to find checksum for ${image_name}" >&2
  exit 1
fi

if [[ "${actual_checksum}" != "${expected_checksum}" ]]; then
  echo "checksum mismatch for ${image_name}" >&2
  exit 1
fi

qemu-img convert -f qcow2 -O raw "${work_dir}/${image_name}" "${output_dir}/disk.img"
printf '%s\n' "${release}" > "${output_dir}/release.txt"

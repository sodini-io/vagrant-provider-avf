#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${repo_root}/scripts/lib/linux-boxes.sh"
keep_failure_artifacts="${AVF_KEEP_FAILURE_ARTIFACTS:-0}"
matrix_root="${AVF_ACCEPTANCE_ROOT:-$(mktemp -d "${TMPDIR:-/tmp}/avf-linux-matrix.XXXXXX")}"
ci_linux_acceptance_command="${AVF_CI_LINUX_ACCEPTANCE_COMMAND:-${repo_root}/scripts/ci-linux-acceptance}"

cleanup() {
  if [[ "${keep_failure_artifacts}" == "0" && -d "${matrix_root}" ]]; then
    rm -rf "${matrix_root}"
  fi
}
trap cleanup EXIT

run_guest() {
  local guest="$1"

  AVF_KEEP_FAILURE_ARTIFACTS="${keep_failure_artifacts}" \
    AVF_ACCEPTANCE_ROOT="${matrix_root}/${guest}" \
    "${ci_linux_acceptance_command}" "${guest}"
}

while IFS= read -r family; do
  run_guest "${family}"
done < <(linux_supported_families)

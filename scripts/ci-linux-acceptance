#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${repo_root}/scripts/lib/linux-boxes.sh"

family="${1:-}"
shift || true

if [[ -z "${family}" ]]; then
  echo "usage: ci-linux-acceptance FAMILY [RSPEC_ARGS...]" >&2
  exit 1
fi

linux_assert_supported_family "${family}" || exit 1

if [[ "$(uname -s)" != "Darwin" || "$(uname -m)" != "arm64" ]]; then
  echo "${family} acceptance requires macOS on Apple Silicon" >&2
  exit 1
fi

cd "${repo_root}"
export AVF_REAL_ACCEPTANCE=1
export AVF_KEEP_FAILURE_ARTIFACTS="${AVF_KEEP_FAILURE_ARTIFACTS:-1}"
export AVF_ACCEPTANCE_ROOT="${AVF_ACCEPTANCE_ROOT:-${repo_root}/build/acceptance/${family}}"

exec bundle exec rspec "$(linux_acceptance_spec "${repo_root}" "${family}")" "$@"

#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
box_path="${1:-${repo_root}/build/boxes/avf-ubuntu-24.04-arm64-0.1.0.box}"
box_name="${BOX_NAME:-avf/ubuntu-24.04-arm64}"
ssh_wait_attempts="${SSH_WAIT_ATTEMPTS:-60}"
ssh_wait_seconds="${SSH_WAIT_SECONDS:-2}"
keep_failure_artifacts="${AVF_KEEP_FAILURE_ARTIFACTS:-0}"
cpus="${CPUS:-2}"
memory_mb="${MEMORY_MB:-2048}"
disk_gb="${DISK_GB:-8}"
created_work_dir=0

wait_for_ssh() {
  local ssh_ready=false

  for ((attempt = 1; attempt <= ssh_wait_attempts; attempt += 1)); do
    if (cd "${work_dir}" && vagrant ssh -c "true" >/dev/null 2>&1); then
      ssh_ready=true
      break
    fi

    sleep "${ssh_wait_seconds}"
  done

  if [[ "${ssh_ready}" != "true" ]]; then
    echo "vagrant ssh did not become ready after ${ssh_wait_attempts} attempts" >&2
    exit 1
  fi
}

ssh_config_value() {
  local key="$1"

  (cd "${work_dir}" && vagrant ssh-config | awk -v key="${key}" '$1 == key { print $2; exit }')
}

if ! command -v vagrant >/dev/null 2>&1; then
  echo "vagrant is required for the smoke workflow" >&2
  exit 1
fi

if [[ ! -f "${box_path}" ]]; then
  echo "box file does not exist: ${box_path}" >&2
  exit 1
fi

if [[ -n "${SMOKE_WORK_DIR:-}" ]]; then
  work_dir="${SMOKE_WORK_DIR}"
  mkdir -p "${work_dir}"
else
  work_dir="$(mktemp -d)"
  created_work_dir=1
fi

cleanup() {
  status=$?

  if [[ "${status}" -ne 0 && "${keep_failure_artifacts}" == "1" ]]; then
    echo "preserving smoke workflow artifacts in ${work_dir}" >&2
    return
  fi

  if [[ -f "${work_dir}/Vagrantfile" ]]; then
    (cd "${work_dir}" && vagrant destroy -f >/dev/null 2>&1) || true
  fi

  if [[ "${created_work_dir}" -eq 1 ]]; then
    rm -rf "${work_dir}"
  fi
}
trap cleanup EXIT

cat > "${work_dir}/Vagrantfile" <<'EOF'
Vagrant.configure("2") do |config|
  config.vm.box = ENV.fetch("BOX_NAME", "avf/ubuntu-24.04-arm64")
  config.vm.box_check_update = false
  config.vm.synced_folder "host-share", "/home/vagrant/workdir", create: true

  config.vm.provider :avf do |avf|
    avf.cpus = Integer(ENV.fetch("CPUS", "2"))
    avf.memory_mb = Integer(ENV.fetch("MEMORY_MB", "2048"))
    avf.disk_gb = Integer(ENV.fetch("DISK_GB", "8"))
  end
end
EOF

export BOX_NAME="${box_name}"
export CPUS="${cpus}"
export MEMORY_MB="${memory_mb}"
export DISK_GB="${disk_gb}"
mkdir -p "${work_dir}/host-share"
printf 'from-host\n' > "${work_dir}/host-share/host.txt"

vagrant box add --force --name "${box_name}" "${box_path}"
(cd "${work_dir}" && vagrant up --provider=avf)
wait_for_ssh

first_ssh_host="$(ssh_config_value HostName)"
first_ssh_port="$(ssh_config_value Port)"
first_ssh_user="$(ssh_config_value User)"

if [[ "${first_ssh_host}" != "127.0.0.1" ]]; then
  echo "expected HostName 127.0.0.1 but got ${first_ssh_host:-<empty>}" >&2
  exit 1
fi

if [[ -z "${first_ssh_port}" ]]; then
  echo "vagrant ssh-config did not report a forwarded SSH port" >&2
  exit 1
fi

if [[ "${first_ssh_user}" != "vagrant" ]]; then
  echo "expected SSH user vagrant but got ${first_ssh_user:-<empty>}" >&2
  exit 1
fi

(cd "${work_dir}" && vagrant ssh -c "id -un && uname -m")
(cd "${work_dir}" && vagrant ssh -c "test -s /etc/machine-id && find /etc/ssh -maxdepth 1 -name 'ssh_host_*_key' | grep -q .")
(cd "${work_dir}" && vagrant ssh -c "test -f /vagrant/Vagrantfile && grep -q from-host /home/vagrant/workdir/host.txt && printf 'from-guest\n' > /home/vagrant/workdir/guest.txt")
grep -q '^from-guest$' "${work_dir}/host-share/guest.txt"
(cd "${work_dir}" && vagrant halt)

if (cd "${work_dir}" && vagrant ssh -c "true" >/dev/null 2>&1); then
  echo "vagrant ssh unexpectedly succeeded after halt" >&2
  exit 1
fi

(cd "${work_dir}" && vagrant up --provider=avf)
wait_for_ssh

second_ssh_port="$(ssh_config_value Port)"
if [[ "${second_ssh_port}" != "${first_ssh_port}" ]]; then
  echo "expected SSH port ${first_ssh_port} after restart but got ${second_ssh_port:-<empty>}" >&2
  exit 1
fi

(cd "${work_dir}" && vagrant ssh -c "id -un && uname -m")
(cd "${work_dir}" && vagrant ssh -c "grep -q from-host /home/vagrant/workdir/host.txt && printf 'from-guest-restart\n' > /home/vagrant/workdir/guest-restart.txt")
grep -q '^from-guest-restart$' "${work_dir}/host-share/guest-restart.txt"
(cd "${work_dir}" && vagrant destroy -f)

if ! (cd "${work_dir}" && vagrant status --machine-readable | grep -q ',state,not_created'); then
  echo "vagrant status did not report not_created after destroy" >&2
  exit 1
fi
